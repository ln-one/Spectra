# =============================================================================
# Spectra Frontend - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API target used by Next.js for server-side requests and /api/v1 proxying
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Internal backend URL used by Next.js when running inside Docker
# Example: INTERNAL_API_URL="http://backend:8000"
# Browser requests go to the current frontend origin and are forwarded by Next.js

# API timeout (ms)
NEXT_PUBLIC_API_TIMEOUT_MS=180000

# Chat timeout (ms)
NEXT_PUBLIC_CHAT_TIMEOUT_MS=300000

# Studio generation timeout (ms)
NEXT_PUBLIC_STUDIO_GENERATION_TIMEOUT_MS=600000
# Word 教案生成单独超时（ms），默认沿用 Studio 生成超时
NEXT_PUBLIC_STUDIO_WORD_GENERATION_TIMEOUT_MS=900000

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Application name (displayed in UI)
NEXT_PUBLIC_APP_NAME="Spectra"

# Application version
NEXT_PUBLIC_APP_VERSION="0.1.0"

# Environment: development, staging, production
NEXT_PUBLIC_ENVIRONMENT="development"

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features during development
NEXT_PUBLIC_ENABLE_AI_GENERATION="true"
NEXT_PUBLIC_ENABLE_FILE_UPLOAD="true"

# -----------------------------------------------------------------------------
# Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file size in bytes (100MB)
NEXT_PUBLIC_MAX_FILE_SIZE=104857600

# -----------------------------------------------------------------------------
# Debug Configuration
# -----------------------------------------------------------------------------
# Enable debug mode
NEXT_PUBLIC_DEBUG="true"

# -----------------------------------------------------------------------------
# Analytics (optional, for production)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
