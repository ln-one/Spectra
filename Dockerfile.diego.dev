FROM python:3.11-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    success=0; \
    for i in 1 2 3; do \
      apt-get update -o Acquire::Retries=8; \
      if apt-get install -y --no-install-recommends --fix-missing nodejs npm ca-certificates; then \
        success=1; \
        break; \
      fi; \
      echo "apt install retry $i failed"; \
      dpkg --configure -a || true; \
      apt-get install -f -y || true; \
      apt-get clean; \
      rm -rf /var/lib/apt/lists/*; \
      sleep 5; \
    done; \
    if [ "$success" -ne 1 ]; then \
      echo "apt install failed after retries"; \
      exit 1; \
    fi; \
    rm -rf /var/lib/apt/lists/*

COPY diego/pyproject.toml diego/README.md ./
COPY diego/service ./service

RUN python -m pip install --upgrade pip \
    && python -m pip install .

COPY diego/package.json diego/package-lock.json ./
RUN npm ci --omit=dev

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "service.api.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]
