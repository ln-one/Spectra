{
  "name": "spectra-api-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Spectra API 文档工具",
  "scripts": {
    "bundle:openapi": "swagger-cli bundle docs/openapi-source.yaml -o docs/openapi.yaml -t yaml",
    "watch:openapi": "nodemon --watch docs/openapi --ext yaml --exec npm run bundle:openapi",
    "validate:openapi": "swagger-cli validate docs/openapi.yaml",
    "sync:openapi": "./scripts/sync-openapi.sh"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "nodemon": "^3.0.2"
  }
}
