# syntax=docker/dockerfile:1.7

FROM python:3.11-bookworm

WORKDIR /app

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    CHROME_PATH=/usr/bin/chromium

ARG TORCH_CPU_INDEX_URL=https://download.pytorch.org/whl/cpu

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    success=0; \
    for i in 1 2 3; do \
      apt-get update -o Acquire::Retries=8; \
      if apt-get install -y --no-install-recommends --fix-missing \
        gcc \
        nodejs \
        npm \
        pandoc \
        chromium \
        libreoffice-core \
        libreoffice-impress \
        fonts-noto-cjk \
        fonts-wqy-zenhei; then \
        success=1; \
        break; \
      fi; \
      echo "apt install retry $i failed"; \
      dpkg --configure -a || true; \
      apt-get install -f -y || true; \
      apt-get clean; \
      rm -rf /var/lib/apt/lists/*; \
      sleep 5; \
    done; \
    if [ "$success" -ne 1 ]; then \
      echo "apt install failed after retries"; \
      exit 1; \
    fi; \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @marp-team/marp-cli

COPY requirements*.txt ./

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --index-url ${TORCH_CPU_INDEX_URL} "torch>=2.1,<3"

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

COPY . .

RUN prisma generate

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
