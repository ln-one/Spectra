# =============================================================================
# Spectra Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL database URL for the shared Spectra runtime.
DATABASE_URL="postgresql://spectra:spectra@postgres:5432/spectra"

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT secret key for token signing (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="your-super-secret-key-change-in-production"

# JWT algorithm
JWT_ALGORITHM="HS256"

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Allow anonymous access (DEVELOPMENT ONLY - set to false in production)
# When true, requests without Authorization header will use a test user ID
ALLOW_ANONYMOUS_ACCESS=true

# -----------------------------------------------------------------------------
# AI/LLM Configuration
# -----------------------------------------------------------------------------
# DashScope API Key (required for Qwen models)
DASHSCOPE_API_KEY="sk-your-dashscope-api-key"

# LlamaParse API Key (required for document parsing)
LLAMAPARSE_API_KEY="llx-your-llamaparse-api-key"

# Document parser provider: local | mineru | mineru_api | mineru_cloud | llamaparse | auto
# - local: 本地轻量解析（pypdf/python-docx/python-pptx，默认）
# - mineru: MinerU (magic-pdf)，需安装 magic-pdf
# - llamaparse: LlamaParse 云端 API，需安装 llama-parse + 设置 LLAMAPARSE_API_KEY
# 详见 ADR-005 及 backend/services/parsers/README.md
DOCUMENT_PARSER="local"

# Self-hosted MinerU FastAPI
# MINERU_API_URL="http://host.docker.internal:18000"
# MINERU_API_FILE_FIELD="files"
# MINERU_API_TIMEOUT_SECONDS=300

# Official MinerU cloud API
# MINERU_CLOUD_API_TOKEN="your-mineru-cloud-token"
# MINERU_CLOUD_API_BASE_URL="https://mineru.net"
# MINERU_CLOUD_MODEL_VERSION="vlm"
# MINERU_CLOUD_LANGUAGE="ch"
# MINERU_CLOUD_ENABLE_FORMULA=true
# MINERU_CLOUD_ENABLE_TABLE=true
# MINERU_CLOUD_IS_OCR=false
# MINERU_CLOUD_POLL_INTERVAL_SECONDS=3
# MINERU_CLOUD_TIMEOUT_SECONDS=600

# Dualweave runtime + Spectra upload orchestration service
DUALWEAVE_ENABLED=true
DUALWEAVE_BASE_URL="http://dualweave:8080"
DUALWEAVE_TIMEOUT_SECONDS=600
DUALWEAVE_POLL_INTERVAL_SECONDS=2
DUALWEAVE_RECONCILE_DELAY_SECONDS=5
DUALWEAVE_ADDR=":8080"
DUALWEAVE_LOCAL_DIR="/var/lib/dualweave/uploads"
DUALWEAVE_HTTP_TIMEOUT="30s"
DUALWEAVE_READ_TIMEOUT="30s"
DUALWEAVE_WRITE_TIMEOUT="10m"
DUALWEAVE_IDLE_TIMEOUT="2m"
DUALWEAVE_WORKFLOW_POLL_INTERVAL="3s"
DUALWEAVE_WORKFLOW_TIMEOUT="10m"
DUALWEAVE_CHUNK_SIZE="1048576"
DUALWEAVE_SMALL_FILE_THRESHOLD_BYTES="2097152"
DUALWEAVE_INLINE_FAST_PATH_ENABLED=true
DUALWEAVE_UNKNOWN_SIZE_USES_SPOOL=true
DUALWEAVE_INLINE_REMOTE_TIMEOUT="250ms"
DUALWEAVE_PER_UPLOAD_BACKLOG_CAP_BYTES="100663296"
DUALWEAVE_PENDING_REMOTE_GRACE_PERIOD="100ms"
DUALWEAVE_SENDER_RETRY_ATTEMPTS=2
DUALWEAVE_NODE_SPOOL_CAPACITY_CAP_BYTES="268435456"
DUALWEAVE_NODE_INLINE_FALLBACK_THRESHOLD_BYTES="120586240"
DUALWEAVE_NODE_SMALL_FILE_INLINE_GRACE_BYTES="33554432"
DUALWEAVE_ARTIFACT_RETENTION_COMPLETED="0s"
DUALWEAVE_ARTIFACT_RETENTION_TERMINAL_FAILURE="0s"
DUALWEAVE_EXECUTION_LOCAL_BASE_DIR="./data"
DUALWEAVE_EXECUTION_LOCAL_DURABILITY_MODE="sync_every_bytes"
DUALWEAVE_EXECUTION_LOCAL_SYNC_EVERY_BYTES=1048576
DUALWEAVE_EXECUTION_CHUNK_SIZE=1048576
DUALWEAVE_EXECUTION_SMALL_FILE_THRESHOLD_BYTES=2097152
DUALWEAVE_EXECUTION_INLINE_FAST_PATH_ENABLED=true
DUALWEAVE_EXECUTION_UNKNOWN_SIZE_USES_SPOOL=true
DUALWEAVE_EXECUTION_INLINE_REMOTE_TIMEOUT="250ms"
DUALWEAVE_EXECUTION_PER_UPLOAD_BACKLOG_CAP_BYTES=100663296
DUALWEAVE_EXECUTION_PENDING_REMOTE_GRACE_PERIOD="100ms"
DUALWEAVE_EXECUTION_SENDER_RETRY_ATTEMPTS=2
DUALWEAVE_EXECUTION_NODE_SPOOL_CAPACITY_CAP_BYTES=268435456
DUALWEAVE_EXECUTION_NODE_INLINE_FALLBACK_THRESHOLD_BYTES=120586240
DUALWEAVE_EXECUTION_NODE_SMALL_FILE_INLINE_GRACE_BYTES=33554432
DUALWEAVE_EXECUTION_COMPLETED_RETENTION="0s"
DUALWEAVE_EXECUTION_TERMINAL_FAILURE_RETENTION="0s"
DUALWEAVE_DOCUMENT_BASE_URL="https://mineru.net"
DUALWEAVE_DOCUMENT_TOKEN_ENV="MINERU_CLOUD_API_TOKEN"
DUALWEAVE_DOCUMENT_AUTH_HEADER="Authorization"
DUALWEAVE_DOCUMENT_AUTH_PREFIX="Bearer"
DUALWEAVE_DOCUMENT_LABEL="document_parse_http"
DUALWEAVE_DOCUMENT_MODEL_VERSION="vlm"
DUALWEAVE_DOCUMENT_LANGUAGE="ch"
DUALWEAVE_DOCUMENT_ENABLE_FORMULA=true
DUALWEAVE_DOCUMENT_ENABLE_TABLE=true
DUALWEAVE_DOCUMENT_IS_OCR=false
DUALWEAVE_DOCUMENT_PREPARE_UPLOAD_URL_PATH="data.file_urls.0"
DUALWEAVE_DOCUMENT_PREPARE_DELIVERY_ID_PATH="data.batch_id"
DUALWEAVE_DOCUMENT_PREPARE_JOB_ID_PATH="data.batch_id"
DUALWEAVE_DOCUMENT_PREPARE_BATCH_ID_PATH="data.batch_id"
DUALWEAVE_DOCUMENT_WORKFLOW_URL="https://mineru.net/api/v4/extract-results/batch/{job_id}"
DUALWEAVE_DOCUMENT_WORKFLOW_METHOD="GET"
DUALWEAVE_DOCUMENT_WORKFLOW_STATUS_PATH="data.extract_result.0.state"
DUALWEAVE_DOCUMENT_WORKFLOW_RESULT_URL_PATH="data.extract_result.0.full_zip_url"
DUALWEAVE_DOCUMENT_WORKFLOW_FILE_NAME_PATH="data.extract_result.0.file_name"
DUALWEAVE_DOCUMENT_WORKFLOW_STATE_PATH="data.extract_result.0.state"
DUALWEAVE_DOCUMENT_WORKFLOW_DATA_ID_PATH="data.extract_result.0.data_id"
DUALWEAVE_DOCUMENT_UPLOAD_METHOD="PUT"
DUALWEAVE_DOCUMENT_POLL_INTERVAL="3s"
DUALWEAVE_DOCUMENT_TIMEOUT="10m"
DUALWEAVE_IMAGE_BASE_URL="https://api.ocr.space/parse/image"
DUALWEAVE_IMAGE_API_KEY_ENV="OCRSPACE_API_KEY"
DUALWEAVE_IMAGE_AUTH_HEADER="apikey"
DUALWEAVE_IMAGE_SEND_LABEL="image_ocr_http"
DUALWEAVE_IMAGE_LANGUAGE="chs"
DUALWEAVE_IMAGE_OVERLAY_REQUIRED=false
DUALWEAVE_IMAGE_OCR_ENGINE="2"
DUALWEAVE_IMAGE_IS_TABLE=false
DUALWEAVE_IMAGE_RESULT_TEXT_PATH="ParsedResults.0.ParsedText"
DUALWEAVE_IMAGE_RESULT_URL_PATH="SearchablePDFURL"
DUALWEAVE_IMAGE_METADATA_OCR_EXIT_CODE_PATH="OCRExitCode"
DUALWEAVE_IMAGE_METADATA_ERRORED_PATH="IsErroredOnProcessing"
DUALWEAVE_IMAGE_METADATA_SEARCHABLE_PDF_URL_PATH="SearchablePDFURL"
DUALWEAVE_IMAGE_POLL_INTERVAL="3s"
DUALWEAVE_IMAGE_TIMEOUT="10m"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com"

# OpenAI API Key (optional, for GPT models)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# MiniMax API Key (required for MiniMax models)
MINIMAX_API_KEY="your-minimax-api-key"

# MiniMax API Base (optional)
# - International: https://api.minimax.io/v1
# - China: https://api.minimaxi.com/v1
# MINIMAX_API_BASE="https://api.minimax.io/v1"

# Default model to use
# - Qwen example: qwen3.5-flash (auto resolved to dashscope/qwen3.5-flash)
# - MiniMax example: minimax/MiniMax-M2.1 or MiniMax-M2.1
DEFAULT_MODEL="qwen3.5-flash"
LARGE_MODEL="qwen3.5-plus"
SMALL_MODEL="qwen3.5-flash"
AI_REQUEST_TIMEOUT_SECONDS=240
CHAT_RESPONSE_TIMEOUT_SECONDS=300
AI_UPSTREAM_RETRY_ATTEMPTS=1
AI_UPSTREAM_RETRY_DELAY_SECONDS=0.35
# 大纲草拟阶段超时时间（秒），用于避免会话长时间阻塞在 DRAFTING_OUTLINE。
OUTLINE_DRAFT_TIMEOUT_SECONDS=240
# preview 接口在缓存缺失时重建内容的超时时间（秒）
PREVIEW_REBUILD_TIMEOUT_SECONDS=8
# 工具可用性检测缓存（秒）。>0 开启，0 关闭（每次都探测）。
TOOL_CHECK_CACHE_TTL_SECONDS=300
# 健康检查中工具探测超时时间（秒）。
HEALTH_TOOL_TIMEOUT_SECONDS=2
# 是否将 Marp/Pandoc 工具链纳入 /health 强约束（缺失时返回 degraded/503）。
GENERATION_TOOLS_REQUIRED=false

# AI 调用失败时是否返回占位 stub 文本（开发调试可设 true，生产建议 false）
ALLOW_AI_STUB=false

# Studio tool card generation mode:
# - strict: AI generation is required; on failure return structured error and do not persist template artifacts.
# - allow: permit fallback template payloads for local testing.
STUDIO_TOOL_FALLBACK_MODE="strict"
# Studio tool AI generation switch.
STUDIO_TOOL_ENABLE_AI_GENERATION=true

# 课件生成失败时是否允许返回模板 fallback 内容（开发调试可设 true，生产建议 false）
ALLOW_COURSEWARE_FALLBACK=false
# artifact 静默沉淀（silent accretion）写入知识库的超时时间（秒），<=0 表示不设超时。
ARTIFACT_SILENT_ACCRETION_TIMEOUT_SECONDS=8

# -----------------------------------------------------------------------------
# Redis & Task Queue Configuration
# -----------------------------------------------------------------------------
# Redis server host
REDIS_HOST="redis"

# Redis server port
REDIS_PORT=6379

# Redis database number
REDIS_DB=0

# Redis password (leave empty for no password in development)
REDIS_PASSWORD=""

# RQ queue default timeout in seconds (30 minutes)
RQ_QUEUE_DEFAULT_TIMEOUT=1800

# RQ result TTL in seconds (24 hours)
RQ_RESULT_TTL=86400

# RQ failure TTL in seconds (7 days)
RQ_FAILURE_TTL=604800

# Queue worker freshness threshold in seconds.
# Docker + SimpleWorker 空闲时心跳可能超过 45 秒，建议与 worker_ttl 对齐。
RQ_WORKER_HEARTBEAT_FRESHNESS_SECONDS=420

# -----------------------------------------------------------------------------
# Retrieval Configuration
# -----------------------------------------------------------------------------
STRATUMIND_ENABLED=true
STRATUMIND_BASE_URL="http://stratumind:8110"
STRATUMIND_TIMEOUT_SECONDS=15
QDRANT_URL="http://qdrant:6333"
QDRANT_COLLECTION_TEXT="stratumind_text_chunks"
QDRANT_COLLECTION_TEXT_ACTIVE="stratumind_text_chunks_v2"

# Embedding model for vector generation
EMBEDDING_MODEL="text-embedding-v3"

# Embedding vector dimension
EMBEDDING_DIMENSION=1024

# Whether to allow local sentence-transformers fallback when remote embedding fails.
# Keep false in most environments to avoid mixed-dimension vectors in the same collection.
EMBEDDING_ALLOW_LOCAL_FALLBACK=false

# Interactive chat should degrade quickly when RAG is unavailable
CHAT_RAG_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# File Storage Configuration
# -----------------------------------------------------------------------------
# Storage type: local (development) or oss (production)
STORAGE_TYPE="local"

# Upload directory (relative to backend directory)
UPLOAD_DIR="/var/lib/spectra/uploads"
ARTIFACT_STORAGE_DIR="/var/lib/spectra/artifacts"
GENERATED_DIR="/var/lib/spectra/generated"
PAGEVRA_ENABLED=true
PAGEVRA_BASE_URL="http://pagevra:8090"
PAGEVRA_TIMEOUT_SECONDS=180
PAGEVRA_DISTRIBUTION="image"
CHROME_PATH="/usr/bin/chromium"
# Diego PPT generation service.
LLM_API_STYLE=openai_chat
LLM_BASE_URL="https://api.minimaxi.com/v1"
LLM_API_KEY=""
LLM_MODEL="minimax-m2.7"
LLM_TIMEOUT_SEC=180
LLM_MAX_RETRIES=5
LLM_TEMPERATURE_OUTLINE=0.4
LLM_TEMPERATURE_SLIDE=0.7
GENERATION_ENGINE=agentic_v2
SLIDE_CONCURRENCY=5
SLIDE_RETRY=2
QA_ENABLED=1
REPAIR_ROUNDS=3
MAX_SLIDE_REPAIR_ROUNDS=4
DEBUG_KEEP_PREVIEWS=0
OUTLINE_TIMEOUT_RETRIES=5
OUTLINE_TIMEOUT_BACKOFF_SEC=5
OUTLINE_STRUCTURED_OUTPUT=1
LLM_REQUEST_CONCURRENCY=10
LLM_CONCURRENCY_BUILD=5
LLM_CONCURRENCY_EVALUATE=2
LLM_CONCURRENCY_REPAIR=4
SLIDE_CANDIDATE_WORKERS=1
LLM_TIMEOUT_JITTER_SEC=2.0
TIMEOUT_STREAK_DEGRADE_THRESHOLD=2
TIMEOUT_STREAK_RECOVER_WINDOW_SEC=200
LLM_SANITIZE_THINK_TAGS=1
LLM_JSON_REPAIR_RETRY=1
SLIDE_FATAL_EARLY_STOP_ROUNDS=2
RUN_MAX_LLM_CALLS=200
KEEP_FAILED_CANDIDATE_JS=1
SLIDE_AUTO_CANONICALIZE=1
SLIDE_DIAG_MAX_JS_LINES=260
SLIDE_DIAG_MAX_STDERR_CHARS=12000
PREVIEW_QA_CONCURRENCY=4
ASSET_FETCH_CONCURRENCY=4
QA_FINALIZE_TIMEOUT_SEC=300
ASSET_PROVIDER=pexels
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=""
ASSET_TIMEOUT_SEC=20
ASSET_MAX_RETRIES=2
DIEGO_LLM_API_STYLE=openai_chat
DIEGO_LLM_BASE_URL="https://api.minimaxi.com/v1"
DIEGO_LLM_API_KEY=""
DIEGO_LLM_MODEL="minimax-m2.7"
DIEGO_LLM_TIMEOUT_SEC=180
DIEGO_LLM_MAX_RETRIES=5
DIEGO_OUTLINE_TIMEOUT_RETRIES=5
DIEGO_OUTLINE_TIMEOUT_BACKOFF_SEC=5
DIEGO_LLM_TEMPERATURE_OUTLINE=0.4
DIEGO_LLM_TEMPERATURE_SLIDE=0.7
DIEGO_GENERATION_ENGINE=agentic_v2
DIEGO_SLIDE_CONCURRENCY=5
DIEGO_SLIDE_RETRY=2
DIEGO_QA_ENABLED=1
DIEGO_REPAIR_ROUNDS=3
DIEGO_MAX_SLIDE_REPAIR_ROUNDS=4
DIEGO_DEBUG_KEEP_PREVIEWS=0
DIEGO_OUTLINE_STRUCTURED_OUTPUT=1
DIEGO_LLM_REQUEST_CONCURRENCY=10
DIEGO_LLM_CONCURRENCY_BUILD=5
DIEGO_LLM_CONCURRENCY_EVALUATE=2
DIEGO_LLM_CONCURRENCY_REPAIR=4
DIEGO_SLIDE_CANDIDATE_WORKERS=1
DIEGO_LLM_TIMEOUT_JITTER_SEC=2.0
DIEGO_TIMEOUT_STREAK_DEGRADE_THRESHOLD=2
DIEGO_TIMEOUT_STREAK_RECOVER_WINDOW_SEC=200
DIEGO_LLM_SANITIZE_THINK_TAGS=1
DIEGO_LLM_JSON_REPAIR_RETRY=1
DIEGO_SLIDE_FATAL_EARLY_STOP_ROUNDS=2
DIEGO_RUN_MAX_LLM_CALLS=200
DIEGO_KEEP_FAILED_CANDIDATE_JS=1
DIEGO_SLIDE_AUTO_CANONICALIZE=1
DIEGO_SLIDE_DIAG_MAX_JS_LINES=260
DIEGO_SLIDE_DIAG_MAX_STDERR_CHARS=12000
DIEGO_PREVIEW_QA_CONCURRENCY=4
DIEGO_ASSET_FETCH_CONCURRENCY=4
DIEGO_QA_FINALIZE_TIMEOUT_SEC=300
DIEGO_ASSET_PROVIDER=pexels
DIEGO_UNSPLASH_ACCESS_KEY=
DIEGO_PEXELS_API_KEY=""
DIEGO_ASSET_TIMEOUT_SEC=20
DIEGO_ASSET_MAX_RETRIES=2
DIEGO_ENABLED=true
DIEGO_BASE_URL="http://diego:8000"
DIEGO_TIMEOUT_SECONDS=120
DIEGO_POLL_INTERVAL_SECONDS=2
DIEGO_OUTLINE_SYNC_TIMEOUT_SECONDS=420
DIEGO_GENERATION_SYNC_TIMEOUT_SECONDS=3600
OUROGRAPH_ENABLED=true
OUROGRAPH_BASE_URL="http://ourograph:8101"
OUROGRAPH_TIMEOUT_SECONDS=30
OUROGRAPH_DATABASE_URL="postgresql://spectra:spectra@postgres:5432/ourograph"
DB_REQUIRED=true
REDIS_REQUIRED=false
UVICORN_RELOAD=false
STRATUMIND_EMBEDDING_MODEL="text-embedding-v3"
STRATUMIND_EMBEDDING_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
STRATUMIND_EMBEDDING_DIMENSION=1024
STRATUMIND_RERANK_ENABLED=true
STRATUMIND_RERANK_BASE_URL="http://dualweave:8080"
STRATUMIND_RERANK_CANDIDATE_K=20
STRATUMIND_RERANK_TIMEOUT_SECONDS=10
STRATUMIND_RERANK_MODEL="qwen3-rerank"
DUALWEAVE_TEXT_RERANK_PROVIDER="dashscope"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com"
DASHSCOPE_TEXT_RERANK_MODEL="qwen3-rerank"
# Maximum file size in bytes (100MB for video support)
MAX_FILE_SIZE=104857600

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=".pdf,.docx,.pptx,.mp4,.mov"

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Debug mode (True for development, False for production)
DEBUG=True

# Server host and port
HOST="0.0.0.0"
PORT=8000

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins (comma-separated, use * for all in development)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="DEBUG"

# Log format: json or text
LOG_FORMAT="json"

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
WORKER_NAME="worker-1"
WORKER_RECOVERY_SCAN=true
RQ_WORKER_COUNT=3

# -----------------------------------------------------------------------------
# PostgreSQL Backup/Restore Configuration
# -----------------------------------------------------------------------------
POSTGRES_BACKUP_DIR="./backup"
POSTGRES_RESTORE_STAGING_DIR="./backup/restore-staging"
POSTGRES_BACKUP_RETENTION_DAYS=14
POSTGRES_BACKUP_PREFIX="spectra-dev"
