generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户与认证
// ============================================

/// 用户模型 - 存储用户账号信息
model User {
  id        String   @id @default(uuid())
  identityId String? @unique
  email     String   @unique
  password  String?  // identity mirror: local password auth removed
  username  String   @unique
  fullName  String?

  // 关联关系
  projects  Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identityId])
  @@index([email])
  @@index([username])
}

/// 幂等性键 - 防止重复请求
/// REVIEW #B3 (P0): 该模型缺少 userId/expiresAt 维度，难以支撑按用户隔离与过期治理的幂等设计（见 security.md 示例）。
model IdempotencyKey {
  key       String   @id
  response  String   // JSON 格式的响应
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ============================================
// 核心业务模型
// ============================================

/// 项目模型 - 存储课件项目的基础信息和教学配置
model Project {
  id          String   @id @default(uuid())

  // 用户关联
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String   // 项目名称，如"五年级数学-分数加减法"
  nameSource  String   @default("default")
  nameUpdatedAt DateTime?
  nameGenerationRequestedAt DateTime?
  description String?  // 项目描述

  // 教学信息
  subject             String?  // 学科：语文/数学/英语/物理/化学等
  gradeLevel          String?  // 学段：小学/初中/高中
  duration            Int?     // 课时（分钟），如 40、45、90
  teachingObjectives  String?  // 教学目标（JSON 格式）

  // 状态管理
  status      String   @default("draft")  // draft/in_progress/completed

  // 空间权限与引用状态
  visibility        String   @default("private") // private/shared
  isReferenceable   Boolean  @default(false)
  currentVersionId  String?  @unique
  currentVersion    ProjectVersion? @relation("ProjectCurrentVersion", fields: [currentVersionId], references: [id])

  // 关联关系
  conversations      Conversation[]
  uploads            Upload[]
  generationSessions GenerationSession[]
  references         ProjectReference[]
  incomingReferences ProjectReference[] @relation("ProjectReferenceTarget")
  versions           ProjectVersion[] @relation("ProjectVersions")
  artifacts          Artifact[]
  candidateChanges   CandidateChange[]
  members            ProjectMember[]
  runs               SessionRun[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
}

/// 对话模型 - 存储多轮对话历史
model Conversation {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // session 作用域隔离（C5：同 project 下多 session 不串数据）
  sessionId   String?
  session     GenerationSession? @relation(fields: [sessionId], references: [id])

  role        String   // user/assistant/system
  content     String   // 消息内容
  metadata    String?  // JSON：意图标签、追问类型、关键词等、citations

  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, sessionId, createdAt])
}

/// 上传文件模型 - 存储文件元信息和解析状态
model Upload {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  filename    String   // 原始文件名
  filepath    String   // 存储路径
  fileType    String   // pdf/word/ppt/image/video
  mimeType    String?  // MIME 类型
  size        Int      // 文件大小（字节）

  // 解析状态
  status       String   @default("uploading")  // uploading/parsing/ready/failed
  parseResult  String?  // JSON：解析后的结构化数据
  errorMessage String?  // 解析失败时的错误信息

  // 用途标注（UX 需求）
  usageIntent  String?  // 用户标注的文件用途，如"参考第2页的练习题设计"

  // 关联关系
  chunks      ParsedChunk[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, status])
}

/// 解析片段模型 - 存储文件解析后的可检索片段（用于 RAG）
model ParsedChunk {
  id          String   @id @default(uuid())
  uploadId    String
  upload      Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  content     String   // 片段内容
  chunkIndex  Int      // 片段索引（在文件中的顺序）
  metadata    String?  // JSON：页码、时间戳、标题、场景描述等
  sourceType  String   // pdf/video/image/word/ppt

  createdAt   DateTime @default(now())

  @@index([uploadId, chunkIndex])
}

/// 项目引用关系
model ProjectReference {
  id               String   @id @default(uuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetProjectId  String
  targetProject    Project  @relation("ProjectReferenceTarget", fields: [targetProjectId], references: [id], onDelete: Cascade)

  relationType     String   // base/auxiliary
  mode             String   // follow/pinned
  pinnedVersionId  String?
  priority         Int      @default(0)
  status           String   @default("active") // active/disabled
  createdBy        String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([projectId, relationType])
  @@index([projectId, status])
}

/// 项目正式版本
model ProjectVersion {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation("ProjectVersions", fields: [projectId], references: [id], onDelete: Cascade)
  currentForProject Project? @relation("ProjectCurrentVersion")

  parentVersionId String?
  parentVersion   ProjectVersion? @relation("ProjectVersionParent", fields: [parentVersionId], references: [id])
  childVersions   ProjectVersion[] @relation("ProjectVersionParent")

  summary         String?
  changeType      String   // author-update/merge-change/reference-change/import
  snapshotData    String?  // JSON
  createdBy       String?

  createdAt       DateTime @default(now())

  baseVersionSessions GenerationSession[] @relation("GenerationSessionBaseVersion")
  artifacts       Artifact[]
  candidateChanges CandidateChange[]
}

/// 项目成果（导出/按需外化）
model Artifact {
  id               String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId         String?
  session           GenerationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  basedOnVersionId  String?
  basedOnVersion    ProjectVersion? @relation(fields: [basedOnVersionId], references: [id], onDelete: SetNull)
  ownerUserId       String?
  sessionRuns       SessionRun[]

  type              String   // pptx/docx/mindmap/summary/exercise/html/gif/mp4
  visibility        String   @default("private") // private/project-visible/shared
  storagePath       String?
  metadata          String?  // JSON

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId, type])
  @@index([projectId, visibility])
}

/// 候选变更
model CandidateChange {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId      String?
  session        GenerationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  baseVersionId  String?
  baseVersion    ProjectVersion? @relation(fields: [baseVersionId], references: [id], onDelete: SetNull)

  title          String
  summary        String?
  payload        String?  // JSON
  status         String   @default("pending") // pending/accepted/rejected
  proposerUserId String?
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewComment  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId, status])
  @@index([projectId, sessionId, status])
}

/// 项目成员与权限
model ProjectMember {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String

  role        String   @default("viewer") // owner/editor/viewer
  permissions String?  // JSON: can_view/can_reference/can_collaborate/can_manage
  status      String   @default("active") // active/disabled

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId, status])
}

// ============================================
// 保留的旧模型（兼容性）
// ============================================

/// 课程模型 - 旧模型，保留以兼容现有代码
model Course {
  id        String   @id @default(uuid())
  title     String
  chapters  String   // JSON stored as text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Session-First 会话生成模型（C6）
// ============================================

/// 生成会话 - 可中断、可恢复的课件生成主上下文
model GenerationSession {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  baseVersionId   String?
  baseVersion     ProjectVersion? @relation("GenerationSessionBaseVersion", fields: [baseVersionId], references: [id], onDelete: SetNull)

  // 生成状态（9态状态机）
  state           String   @default("IDLE")
  // IDLE/CONFIGURING/ANALYZING/DRAFTING_OUTLINE/AWAITING_OUTLINE_CONFIRM/
  // GENERATING_CONTENT/RENDERING/SUCCESS/FAILED
  stateReason     String?  // 状态附加说明（灰度/未知状态）

  // 输出配置
  outputType      String   // ppt/word/both
  options         String?  // JSON: GenerationOptions
  progress        Int      @default(0)

  // 大纲版本控制
  currentOutlineVersion Int @default(1)

  // 渲染版本（并发控制）
  renderVersion   Int      @default(0)

  // 生成结果
  pptUrl          String?
  wordUrl         String?

  // 错误信息
  errorCode       String?
  errorMessage    String?
  errorRetryable  Boolean  @default(false)

  // 可恢复性
  resumable       Boolean  @default(false)
  lastCursor      String?  // 最后一个事件游标，用于断线续传

  // 客户端会话 ID（断线重连用）
  clientSessionId String?

  // 展示标题
  displayTitle    String?
  displayTitleSource String? @default("default")
  displayTitleUpdatedAt DateTime?
  displayTitleGenerationRequestedAt DateTime?

  // 能力降级记录（JSON 数组）
  fallbacksJson   String?  // JSON: ExternalFallbackInfo[]

  // 关联关系
  outlineVersions OutlineVersion[]
  events          SessionEvent[]
  conversations   Conversation[]
  artifacts       Artifact[]
  candidateChanges CandidateChange[]
  runs            SessionRun[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, state])
  @@index([projectId, baseVersionId])
  @@index([projectId, updatedAt])
  @@index([userId, state])
  @@index([clientSessionId])
}

/// 会话/工具执行历史
model SessionRun {
  id              String   @id @default(uuid())
  runScopeKey     String
  sessionId       String?
  session         GenerationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  toolType        String
  runNo           Int
  title           String
  titleSource     String   @default("pending")
  titleUpdatedAt  DateTime?
  titleGenerationRequestedAt DateTime?
  status          String   @default("pending")
  step            String   @default("config")
  artifactId      String?
  artifact        Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sessionId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([artifactId])
  @@unique([runScopeKey, toolType, runNo])
}

/// 大纲版本 - 每次用户或 AI 修改大纲时追加一条
model OutlineVersion {
  id            String   @id @default(uuid())
  sessionId     String
  session       GenerationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  version       Int      // 版本号，从 1 开始递增
  outlineData   String   // JSON: OutlineDocument
  changeReason  String?  // 本次变更原因

  createdAt     DateTime @default(now())

  @@unique([sessionId, version])
  @@index([sessionId, version])
}

/// 会话事件 - 追加不可变的事件流（SSE 事件源）
model SessionEvent {
  id            String   @id @default(uuid())
  sessionId     String
  session       GenerationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  eventType     String   // GenerationEventType 枚举
  state         String   // 事件发生时的 GenerationState
  stateReason   String?
  progress      Int?
  cursor        String   @unique  // 事件游标（用于 SSE 断线续传）
  payload       String?  // JSON: 事件业务数据
  schemaVersion Int      @default(1)

  createdAt     DateTime @default(now())

  @@index([sessionId, cursor])
  @@index([sessionId, createdAt])
}
