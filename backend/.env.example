# =============================================================================
# Spectra Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database URL (relative to backend directory)
DATABASE_URL="file:./prisma/dev.db"

# -----------------------------------------------------------------------------
# AI/LLM Configuration
# -----------------------------------------------------------------------------
# OpenAI API Key (required for GPT models)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# LiteLLM supports multiple providers. Set the appropriate key:
# - ANTHROPIC_API_KEY for Claude
# - AZURE_API_KEY for Azure OpenAI

# Default model to use (optional, defaults to gpt-3.5-turbo)
DEFAULT_MODEL="gpt-3.5-turbo"

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Debug mode (True for development, False for production)
DEBUG=True

# Server host and port
HOST="0.0.0.0"
PORT=8000

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Upload directory (relative to backend directory)
UPLOAD_DIR="./uploads"

# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=".pdf,.docx,.pptx,.txt,.md"

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins (comma-separated, use * for all in development)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
