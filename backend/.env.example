# =============================================================================
# Spectra Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL database URL for host-side local development.
# Docker Compose injects its own service-host URL for containers.
DATABASE_URL="postgresql://spectra:spectra@127.0.0.1:5432/spectra"

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT secret key for token signing (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="your-super-secret-key-change-in-production"

# JWT algorithm
JWT_ALGORITHM="HS256"

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Allow anonymous access (DEVELOPMENT ONLY - set to false in production)
# When true, requests without Authorization header will use a test user ID
ALLOW_ANONYMOUS_ACCESS=true

# -----------------------------------------------------------------------------
# AI/LLM Configuration
# -----------------------------------------------------------------------------
# DashScope API Key (required for Qwen models)
DASHSCOPE_API_KEY="sk-your-dashscope-api-key"

# LlamaParse API Key (required for document parsing)
LLAMAPARSE_API_KEY="llx-your-llamaparse-api-key"

# Document parser provider: local | mineru | mineru_api | mineru_cloud | llamaparse | auto
# - local: 本地轻量解析（pypdf/python-docx/python-pptx，默认）
# - mineru: MinerU (magic-pdf)，需安装 magic-pdf
# - llamaparse: LlamaParse 云端 API，需安装 llama-parse + 设置 LLAMAPARSE_API_KEY
# 详见 ADR-005 及 backend/services/parsers/README.md
DOCUMENT_PARSER="local"

# Self-hosted MinerU FastAPI
# MINERU_API_URL="http://host.docker.internal:18000"
# MINERU_API_FILE_FIELD="files"
# MINERU_API_TIMEOUT_SECONDS=300

# Official MinerU cloud API
# MINERU_CLOUD_API_TOKEN="your-mineru-cloud-token"
# MINERU_CLOUD_API_BASE_URL="https://mineru.net"
# MINERU_CLOUD_MODEL_VERSION="vlm"
# MINERU_CLOUD_LANGUAGE="ch"
# MINERU_CLOUD_ENABLE_FORMULA=true
# MINERU_CLOUD_ENABLE_TABLE=true
# MINERU_CLOUD_IS_OCR=false
# MINERU_CLOUD_POLL_INTERVAL_SECONDS=3
# MINERU_CLOUD_TIMEOUT_SECONDS=600

# OpenAI API Key (optional, for GPT models)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# MiniMax API Key (required for MiniMax models)
MINIMAX_API_KEY="your-minimax-api-key"

# MiniMax API Base (optional)
# - International: https://api.minimax.io/v1
# - China: https://api.minimaxi.com/v1
# MINIMAX_API_BASE="https://api.minimax.io/v1"

# Default model to use
# - Qwen example: qwen3.5-flash (auto resolved to dashscope/qwen3.5-flash)
# - MiniMax example: minimax/MiniMax-M2.1 or MiniMax-M2.1
DEFAULT_MODEL="qwen3.5-flash"
LARGE_MODEL="qwen3.5-plus"
SMALL_MODEL="qwen3.5-flash"
AI_REQUEST_TIMEOUT_SECONDS=90
AI_UPSTREAM_RETRY_ATTEMPTS=1
AI_UPSTREAM_RETRY_DELAY_SECONDS=0.35
# 大纲草拟阶段超时时间（秒），用于避免会话长时间阻塞在 DRAFTING_OUTLINE。
OUTLINE_DRAFT_TIMEOUT_SECONDS=90
# preview 接口在缓存缺失时重建内容的超时时间（秒）
PREVIEW_REBUILD_TIMEOUT_SECONDS=8
# 工具可用性检测缓存（秒）。>0 开启，0 关闭（每次都探测）。
TOOL_CHECK_CACHE_TTL_SECONDS=300
# 健康检查中工具探测超时时间（秒）。
HEALTH_TOOL_TIMEOUT_SECONDS=2
# 是否将 Marp/Pandoc 工具链纳入 /health 强约束（缺失时返回 degraded/503）。
GENERATION_TOOLS_REQUIRED=false

# AI 调用失败时是否返回占位 stub 文本（开发调试可设 true，生产建议 false）
ALLOW_AI_STUB=false

# Studio tool card generation mode:
# - strict: AI generation is required; on failure return structured error and do not persist template artifacts.
# - allow: permit fallback template payloads for local testing.
STUDIO_TOOL_FALLBACK_MODE="strict"
# Studio tool AI generation switch.
STUDIO_TOOL_ENABLE_AI_GENERATION=true

# 课件生成失败时是否允许返回模板 fallback 内容（开发调试可设 true，生产建议 false）
ALLOW_COURSEWARE_FALLBACK=false
# Office 产物渲染彻底失败时是否允许生成占位 DOCX/PPTX（仅开发调试建议开启）
ALLOW_OFFICE_PLACEHOLDER_ARTIFACTS=false
# GIF/MP4 等 media 产物尚未正式渲染接入时，是否允许生成占位二进制（仅开发调试建议开启）
ALLOW_MEDIA_PLACEHOLDER_ARTIFACTS=false
# artifact 静默沉淀（silent accretion）写入知识库的超时时间（秒），<=0 表示不设超时。
ARTIFACT_SILENT_ACCRETION_TIMEOUT_SECONDS=8

# -----------------------------------------------------------------------------
# Redis & Task Queue Configuration
# -----------------------------------------------------------------------------
# Redis server host
REDIS_HOST="localhost"

# Redis server port
REDIS_PORT=6379

# Redis database number
REDIS_DB=0

# Redis password (leave empty for no password in development)
REDIS_PASSWORD=""

# RQ queue default timeout in seconds (30 minutes)
RQ_QUEUE_DEFAULT_TIMEOUT=1800

# RQ result TTL in seconds (24 hours)
RQ_RESULT_TTL=86400

# RQ failure TTL in seconds (7 days)
RQ_FAILURE_TTL=604800

# Queue worker freshness threshold in seconds.
# Docker + SimpleWorker 空闲时心跳可能超过 45 秒，建议与 worker_ttl 对齐。
RQ_WORKER_HEARTBEAT_FRESHNESS_SECONDS=420

# -----------------------------------------------------------------------------
# Vector Database Configuration (ChromaDB)
# -----------------------------------------------------------------------------
# ChromaDB server host
CHROMA_MODE="persistent"
CHROMA_HOST="localhost"

# ChromaDB server port
CHROMA_PORT="8001"

# ChromaDB data persistence directory
CHROMA_PERSIST_DIR="./chroma_data"

# Embedding model for vector generation
EMBEDDING_MODEL="text-embedding-v4"

# Embedding vector dimension
EMBEDDING_DIMENSION=1536

# Whether to allow local sentence-transformers fallback when remote embedding fails.
# Keep false in most environments to avoid mixed-dimension vectors in the same collection.
EMBEDDING_ALLOW_LOCAL_FALLBACK=false

# Interactive chat should degrade quickly when RAG is unavailable
CHAT_RAG_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# File Storage Configuration
# -----------------------------------------------------------------------------
# Storage type: local (development) or oss (production)
STORAGE_TYPE="local"

# Upload directory (relative to backend directory)
UPLOAD_DIR="./uploads"
ARTIFACT_STORAGE_DIR="./uploads/artifacts"
GENERATED_DIR="./generated"

# Container-friendly runtime storage defaults (recommended for Docker/cloud):
# UPLOAD_DIR="/var/lib/spectra/uploads"
# ARTIFACT_STORAGE_DIR="/var/lib/spectra/artifacts"
# GENERATED_DIR="/var/lib/spectra/generated"
# CHROMA_PERSIST_DIR="/var/lib/spectra/chroma"

# Maximum file size in bytes (100MB for video support)
MAX_FILE_SIZE=104857600

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=".pdf,.docx,.pptx,.mp4,.mov"

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Debug mode (True for development, False for production)
DEBUG=True

# Server host and port
HOST="0.0.0.0"
PORT=8000

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins (comma-separated, use * for all in development)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="DEBUG"

# Log format: json or text
LOG_FORMAT="json"

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
WORKER_NAME="worker-1"
WORKER_RECOVERY_SCAN=true

# -----------------------------------------------------------------------------
# PostgreSQL Backup/Restore Configuration
# -----------------------------------------------------------------------------
POSTGRES_BACKUP_DIR="./backup"
POSTGRES_RESTORE_STAGING_DIR="./backup/restore-staging"
POSTGRES_BACKUP_RETENTION_DAYS=14
POSTGRES_BACKUP_PREFIX="spectra-dev"
