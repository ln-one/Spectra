FROM python:3.11-bookworm

WORKDIR /app

RUN set -eux; \
    apt-get update -o Acquire::Retries=8; \
    success=0; \
    for i in 1 2 3; do \
      if apt-get install -y --no-install-recommends --fix-missing \
        gcc \
        nodejs \
        npm \
        pandoc \
        chromium \
        libreoffice-core \
        libreoffice-impress \
        fonts-noto-cjk \
        fonts-wqy-zenhei; then \
        success=1; \
        break; \
      fi; \
      echo "apt install retry $i failed"; \
      sleep 5; \
    done; \
    if [ "$success" -ne 1 ]; then \
      echo "apt install failed after retries"; \
      exit 1; \
    fi; \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @marp-team/marp-cli

ENV CHROME_PATH=/usr/bin/chromium

COPY requirements.txt requirements-dev.txt .

# Improve dependency installation resilience on unstable networks.
RUN pip install --no-cache-dir \
    --retries 10 \
    --timeout 300 \
    -i https://pypi.tuna.tsinghua.edu.cn/simple \
    --extra-index-url https://pypi.org/simple \
    -r requirements.txt \
    -r requirements-dev.txt

RUN python -m playwright install chromium

COPY . .

RUN prisma generate

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
